generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NEGOTIATING
  SOLD
  LOST
}

enum LeadSource {
  TELEGRAM_GROUP
  MANUAL
  MINI_APP
  REFERRAL
}

enum SmsStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum CarCategory {
  SEDAN
  SUV
  MINIVAN
  HATCHBACK
  COUPE
  TRUCK
  OTHER
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  password      String
  fullName      String    @map("full_name")
  role          UserRole  @default(MANAGER)
  isActive      Boolean   @default(true) @map("is_active")
  telegramId    String?   @unique @map("telegram_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  assignedLeads Lead[]         @relation("AssignedManager")
  activities    LeadActivity[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Car {
  id           String      @id @default(uuid())
  brand        String
  model        String
  year         Int
  price        Decimal     @db.Decimal(12, 2)
  category     CarCategory @default(SEDAN)
  color        String?
  mileage      Int?
  engine       String?
  transmission String?
  description  String?     @db.Text
  photos       String[]
  videos       String[]
  isActive     Boolean     @default(true) @map("is_active")
  isFeatured   Boolean     @default(false) @map("is_featured")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@map("cars")
}

model Lead {
  id              String     @id @default(uuid())
  phone           String
  name            String?
  source          LeadSource @default(TELEGRAM_GROUP)
  sourceGroup     String?    @map("source_group")
  sourceMessage   String?    @map("source_message") @db.Text
  city            String?
  status          LeadStatus @default(NEW)
  notes           String?    @db.Text
  score           Int        @default(0)
  managerId       String?    @map("manager_id")
  telegramMsgId   Int?       @map("telegram_msg_id")
  interestedCarId String?    @map("interested_car_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  manager          User?             @relation("AssignedManager", fields: [managerId], references: [id])
  activities       LeadActivity[]
  smsMessages      SmsMessage[]
  reminders        Reminder[]
  callbackRequests CallbackRequest[]

  @@unique([phone, source, sourceGroup])
  @@index([status])
  @@index([managerId])
  @@index([createdAt])
  @@map("leads")
}

model MonitoredGroup {
  id          String    @id @default(uuid())
  telegramId  String    @unique @map("telegram_id")
  title       String
  keywords    String[]
  isActive    Boolean   @default(true) @map("is_active")
  lastChecked DateTime? @map("last_checked")
  leadsCount  Int       @default(0) @map("leads_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("monitored_groups")
}

model SmsTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String   @db.Text
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sms_templates")
}

model SmsMessage {
  id        String    @id @default(uuid())
  leadId    String    @map("lead_id")
  phone     String
  message   String    @db.Text
  status    SmsStatus @default(PENDING)
  semysmsId String?   @map("semysms_id")
  error     String?
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([phone])
  @@map("sms_messages")
}

model Reminder {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  message   String
  dueAt     DateTime @map("due_at")
  isSent    Boolean  @default(false) @map("is_sent")
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([dueAt, isSent])
  @@map("reminders")
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  userId    String?  @map("user_id")
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("lead_activities")
}

model AppSettings {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text

  @@map("app_settings")
}

model CallbackRequest {
  id        String   @id @default(uuid())
  leadId    String?  @map("lead_id")
  phone     String
  name      String?
  carId     String?  @map("car_id")
  message   String?
  isHandled Boolean  @default(false) @map("is_handled")
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [id])

  @@map("callback_requests")
}
