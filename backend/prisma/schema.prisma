generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CLOSED
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model MonitoredGroup {
  id             String    @id @default(uuid())
  telegramId     String    @unique @map("telegram_id")
  title          String
  type           String    @default("GROUP")
  isActive       Boolean   @default(true) @map("is_active")
  leadsCount     Int       @default(0) @map("leads_count")
  lastScrapedAt  DateTime? @map("last_scraped_at")
  lastMessageId  Int?      @map("last_message_id")
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  leads Lead[]

  @@map("monitored_groups")
}

model Lead {
  id               String     @id @default(uuid())
  phone            String
  rawPhone         String?    @map("raw_phone")
  rawMessage       String?    @map("raw_message") @db.Text

  brand            String?
  model            String?
  year             Int?
  priceAmount      Decimal?   @map("price_amount") @db.Decimal(12, 2)
  priceCurrency    String?    @map("price_currency")
  color            String?
  mileage          String?
  fuelType         String?    @map("fuel_type")
  transmission     String?
  condition        String?
  creditAvailable  Boolean?   @map("credit_available")
  city             String?

  senderName       String?    @map("sender_name")
  senderUsername   String?    @map("sender_username")

  sourceGroupId    String?    @map("source_group_id")
  sourceGroup      MonitoredGroup? @relation(fields: [sourceGroupId], references: [id])
  sourceMsgId      Int?       @map("source_msg_id")

  status           LeadStatus @default(NEW)
  notes            String?    @db.Text

  smsSent          Boolean    @default(false) @map("sms_sent")
  smsSentAt        DateTime?  @map("sms_sent_at")

  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  smsLogs SmsLog[]

  @@index([phone])
  @@index([brand])
  @@index([city])
  @@index([status])
  @@index([createdAt])
  @@index([sourceGroupId])
  @@map("leads")
}

model SmsLog {
  id        String    @id @default(uuid())
  leadId    String    @map("lead_id")
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  phone     String
  message   String    @db.Text
  status    SmsStatus @default(PENDING)
  response  String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([leadId])
  @@map("sms_logs")
}

model Setting {
  id          String @id @default(uuid())
  key         String @unique
  value       String @db.Text
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
